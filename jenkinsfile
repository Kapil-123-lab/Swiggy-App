pipeline {
    agent any

    tools {
        jdk 'Jdk21'
        nodejs 'node23'
    }

    environment {
        SCANNER_HOME = tool('Sonar-scanner')
        IMAGE_NAME = 'kapilkanaujiya/swiggy'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/Kapil-123-lab/DevOps-Project-Swiggy.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    bat """
                    "%SCANNER_HOME%\\bin\\sonar-scanner.bat" ^
                    -Dsonar.projectKey=Swiggy ^
                    -Dsonar.projectName=Swiggy
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build -t swiggy .'
            }
        }

        stage('Docker Push') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker-creds') {
                        bat 'docker tag swiggy %IMAGE_NAME%:latest'
                        bat 'docker push %IMAGE_NAME%:latest'
                    }
                }
            }
        }

        stage('Deploy Container') {
            steps {
                bat '''
                docker rm -f swiggy
                docker run -d --name swiggy -p 3000:3000 %IMAGE_NAME%:latest
                '''
            }
        }
    }
}
